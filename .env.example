# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development
PUBLIC_BASE_URL=https://your-app.fly.dev
LOG_LEVEL=info

# ── Twilio ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+15551234567
TWILIO_VALIDATE_SIGNATURE=true

# ── ElevenLabs ──────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_22050_32

# ── Supabase ────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Google Calendar ─────────────────────────────────────
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_TIMEZONE=America/Los_Angeles

# ── Notifications ───────────────────────────────────────
OWNER_PHONE=+15550001111
ESCALATE_PHONE=+15550001111

# ── Behavior ────────────────────────────────────────────
SESSION_TTL_MINUTES=30
MAX_REPROMPTS=3
SESSION_STORE=memory
AUDIO_CACHE_DIR=./audio-cache

# ── Dashboard ───────────────────────────────────────────
# Set DASHBOARD_PASSWORD to protect /dashboard routes with HTTP Basic Auth.
# Leave blank in local dev (no auth required).
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=
